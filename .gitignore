# OS
.DS_Store
Thumbs.db
desktop.ini

# IDE
.vscode/
.idea/
*.swp
*.swo

# Dependencies
node_modules/

# Python
__pycache__/
*.pyc
.venv/

# Environment
.env
.env.local

# [V48-SEC Phase 3] Wrangler local dev secrets — NEVER commit.
# Contains CHEESESTOCK_HMAC_SECRET and other per-env secrets used only by
# `wrangler pages dev`. Production secrets live in Cloudflare dashboard
# (Settings -> Environment variables -> Encrypted) via `wrangler secret put`.
# .dev.vars.example is the template (tracked); all other .dev.vars* are ignored.
.dev.vars
.dev.vars.*
!.dev.vars.example

# Stock data (large JSON files — downloaded via scripts/download_ohlcv.py)
# Tracked subdirs: kospi/, kosdaq/, backtest/, macro/ + index.json
data/
!data/index.json
!data/kospi/
!data/kospi/**
!data/kosdaq/
!data/kosdaq/**
!data/backtest/
!data/backtest/*.json
!data/macro/
!data/macro/*.json

# Cron/scheduler logs (generated by --cron mode)
logs/

# Claude Code (AI assistant local config — keep rules/ tracked)
.claude/*
!.claude/rules/

# Runtime state (login guard — prevents Kiwoom account lockout across restarts)
server/.login_guard.json
server/*.log
.wrangler/

# Generated documents (built by scripts/generate_word.py)
docs/*.docx
docs/*.pdf
docs/reference.docx

# TinyTeX installer (one-time use)
scripts/_install_tinytex.py

# Cloudflare Pages staging directory (built by scripts/stage_deploy.py)
# Hard-linked from project root -- never commit
deploy/
# V48 Phase 1: bundled deploy outputs (built by scripts/build.mjs)
deploy.bundled/
deploy.raw/
# V48 Phase 1: stage-time generated functions/_data/ JSONs (copied from data/backtest/)
functions/_data/*.json
