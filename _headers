# Cloudflare Pages custom headers

# SW 자체는 항상 네트워크에서 최신 확인
/sw.js
  Cache-Control: no-cache

# index.html도 항상 재검증 (SW 등록 트리거)
/index.html
  Cache-Control: no-cache

# JS/CSS: 짧은 캐시 + 재검증
/js/*
  Cache-Control: public, max-age=3600, must-revalidate
/css/*
  Cache-Control: public, max-age=3600, must-revalidate
