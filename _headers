/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()

/sw.js
  Cache-Control: no-cache

/index.html
  Cache-Control: no-cache
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://unpkg.com; style-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://fonts.googleapis.com; font-src 'self' https://cdn.jsdelivr.net https://fonts.gstatic.com; img-src 'self' data:; connect-src 'self' wss://ws.cheesestock.co.kr ws://localhost:8765; worker-src 'self'

/js/*
  Cache-Control: public, max-age=3600, must-revalidate

/css/*
  Cache-Control: public, max-age=3600, must-revalidate

/data/*
  Cache-Control: public, max-age=3600, stale-while-revalidate=86400

# V48-Phase2: per-stock + per-context dynamic responses must not be cached.
# Endpoint handlers also set Cache-Control: no-store; this provides edge-level
# defense-in-depth so any future function-level cache misconfig is caught.
/api/*
  Cache-Control: no-store
  X-Robots-Tag: noindex
